      "post": {
        "tags": ["Campaigns"],
        "summary": "Create a new campaign",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "agent_id", "phone_number_id"],
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Campaign name"
                  },
                  "description": {
                    "type": "string",
                    "description": "Campaign description"
                  },
                  "agent_id": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Agent ID"
                  },
                  "phone_number_id": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Phone number ID"
                  },
                  "max_calls_per_hour": {
                    "type": "integer",
                    "description": "Maximum calls per hour"
                  },
                  "max_calls_per_day": {
                    "type": "integer",
                    "description": "Maximum calls per day"
                  },
                  "voicemail_hours": {
                    "type": "integer",
                    "description": "Hours to wait after voicemail calls"
                  },
                  "auto_add_to_dnc": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": ["completed", "voicemail"]
                    },
                    "description": "Call statuses that trigger auto-add to DNC"
                  }
                }
              },
              "example": {
                "name": "Customer Outreach Campaign",
                "description": "Outreach campaign for existing customers",
                "agent_id": "123e4567-e89b-12d3-a456-426614174000",
                "phone_number_id": "456e4567-e89b-12d3-a456-426614174000",
                "max_calls_per_hour": 10,
                "max_calls_per_day": 100,
                "voicemail_hours": 24,
                "auto_add_to_dnc": ["completed", "voicemail"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Campaign created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Campaign"
                }
              }
            }
          },
          "422": {
            "description": "Validation error"
          }
        },
