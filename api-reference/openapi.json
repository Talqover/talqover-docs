  "paths": {
    "/user": {
      "get": {
        "tags": ["User"],
        "summary": "Get authenticated user information",
        "security": [
          {
            "sanctum": []
          }
        ],
        "responses": {
          "200": {
            "description": "User information retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "401": {
            "description": "Unauthenticated"
          }
        },
        "x-code-samples": {
          "curl": {
            "lang": "curl",
            "source": "curl -X GET \\\n  'https://talqover.app/api/v1/user' \\\n  -H 'Authorization: Bearer YOUR_TOKEN'"
          },
          "php": {
            "lang": "php",
            "source": "<?php\n\n$client = new \\GuzzleHttp\\Client();\n$response = $client->get('https://talqover.app/api/v1/user', [\n    'headers' => [\n        'Authorization' => 'Bearer YOUR_TOKEN',\n    ],\n]);\n$data = json_decode($response->getBody());"
          },
          "nodejs": {
            "lang": "javascript",
            "source": "const axios = require('axios');\n\nconst response = await axios.get('https://talqover.app/api/v1/user', {\n  headers: {\n    'Authorization': 'Bearer YOUR_TOKEN'\n  }\n});\nconst data = response.data;"
          }
        }
      }
    },
    "/agents": {
      "get": {
        "tags": ["Agents"],
        "summary": "List voice agents",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["draft", "published"]
            },
            "description": "Filter by agent status"
          },
          {
            "name": "direction",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["inbound", "outbound"]
            },
            "description": "Filter by call direction"
          },
          {
            "name": "search",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Search by agent name or label"
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20
            },
            "description": "Number of items per page"
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Page number for pagination"
          }
        ],
        "responses": {
          "200": {
            "description": "List of agents retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Agent"
                      }
                    },
                    "meta": {
                      "$ref": "#/components/schemas/PaginationMeta"
                    }
                  }
                }
              }
            }
          }
        },
        "x-code-samples": {
          "curl": {
            "lang": "curl",
            "source": "curl -X GET \\\n  'https://talqover.app/api/v1/agents' \\\n  -H 'Authorization: Bearer YOUR_TOKEN'"
          },
          "php": {
            "lang": "php",
            "source": "<?php\n\n$client = new \\GuzzleHttp\\Client();\n$response = $client->get('https://talqover.app/api/v1/agents', [\n    'headers' => [\n        'Authorization' => 'Bearer YOUR_TOKEN',\n    ],\n]);\n$data = json_decode($response->getBody());"
          },
          "nodejs": {
            "lang": "javascript",
            "source": "const axios = require('axios');\n\nconst response = await axios.get('https://talqover.app/api/v1/agents', {\n  headers: {\n    'Authorization': 'Bearer YOUR_TOKEN'\n  }\n});\nconst data = response.data;"
          }
        }
      },
      "post": {
        "tags": ["Agents"],
        "summary": "Create a new voice agent",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["label", "name", "language", "interrupt_sensitivity", "endpointing_sensitivity", "ivr_navigation_mode", "conversation_speed", "initial_message_delay", "ask_if_human_present_on_idle", "idle_time_seconds", "llm_temperature", "enable_recording", "direction", "who_speaks_first"],
                "properties": {
                  "label": {
                    "type": "string",
                    "maxLength": 255,
                    "description": "Agent label"
                  },
                  "description": {
                    "type": "string",
                    "description": "Agent description"
                  },
                  "name": {
                    "type": "string",
                    "maxLength": 255,
                    "description": "Agent name"
                  },
                  "language": {
                    "type": "string",
                    "description": "Agent language (e.g., en-US, pt-BR, es-ES)"
                  },
                  "initial_message": {
                    "type": "string",
                    "description": "Initial message the agent will say"
                  },
                  "interrupt_sensitivity": {
                    "type": "string",
                    "enum": ["low", "medium", "high"],
                    "description": "Interrupt sensitivity level"
                  },
                  "endpointing_sensitivity": {
                    "type": "string",
                    "maxLength": 255,
                    "description": "Endpointing sensitivity"
                  },
                  "ivr_navigation_mode": {
                    "type": "string",
                    "maxLength": 255,
                    "description": "IVR navigation mode"
                  },
                  "conversation_speed": {
                    "type": "number",
                    "minimum": 0.1,
                    "maximum": 3.0,
                    "description": "Conversation speed"
                  },
                  "initial_message_delay": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 60,
                    "description": "Initial message delay in seconds"
                  },
                  "ask_if_human_present_on_idle": {
                    "type": "boolean",
                    "description": "Whether to ask if human is present when idle"
                  },
                  "idle_time_seconds": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 300,
                    "description": "Idle time in seconds"
                  },
                  "llm_temperature": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 2,
                    "description": "LLM temperature"
                  },
                  "enable_recording": {
                    "type": "boolean",
                    "description": "Whether to enable call recording"
                  },
                  "direction": {
                    "type": "string",
                    "enum": ["inbound", "outbound"],
                    "description": "Call direction"
                  },
                  "who_speaks_first": {
                    "type": "string",
                    "enum": ["agent", "user"],
                    "description": "Who speaks first"
                  }
                }
              },
              "example": {
                "label": "Customer Service Agent",
                "description": "A helpful customer service agent",
                "name": "Customer Service Agent",
                "language": "en-US",
                "initial_message": "Hello, how can I help you today?",
                "interrupt_sensitivity": "medium",
                "endpointing_sensitivity": "medium",
                "ivr_navigation_mode": "standard",
                "conversation_speed": 1.0,
                "initial_message_delay": 2,
                "ask_if_human_present_on_idle": true,
                "idle_time_seconds": 30,
                "llm_temperature": 0.7,
                "enable_recording": true,
                "direction": "inbound",
                "who_speaks_first": "agent"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Agent created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Agent"
                }
              }
            }
          },
          "422": {
            "description": "Validation error"
          }
        },
        "x-code-samples": {
          "curl": {
            "lang": "curl",
            "source": "curl -X POST \\\n  'https://talqover.app/api/v1/agents' \\\n  -H 'Content-Type: application/json' \\\n  -H 'Authorization: Bearer YOUR_TOKEN' \\\n  -d '{\n    \"label\": \"Customer Service Agent\",\n    \"name\": \"Customer Service Agent\",\n    \"language\": \"en-US\",\n    \"interrupt_sensitivity\": \"medium\",\n    \"endpointing_sensitivity\": \"medium\",\n    \"ivr_navigation_mode\": \"standard\",\n    \"conversation_speed\": 1.0,\n    \"initial_message_delay\": 2,\n    \"ask_if_human_present_on_idle\": true,\n    \"idle_time_seconds\": 30,\n    \"llm_temperature\": 0.7,\n    \"enable_recording\": true,\n    \"direction\": \"inbound\",\n    \"who_speaks_first\": \"agent\"\n  }'"
          },
          "php": {
            "lang": "php",
            "source": "<?php\n\n$client = new \\GuzzleHttp\\Client();\n$response = $client->post('https://talqover.app/api/v1/agents', [\n    'headers' => [\n        'Authorization' => 'Bearer YOUR_TOKEN',\n        'Content-Type' => 'application/json',\n    ],\n    'json' => [\n        'label' => 'Customer Service Agent',\n        'name' => 'Customer Service Agent',\n        'language' => 'en-US',\n        'interrupt_sensitivity' => 'medium',\n        'endpointing_sensitivity' => 'medium',\n        'ivr_navigation_mode' => 'standard',\n        'conversation_speed' => 1.0,\n        'initial_message_delay' => 2,\n        'ask_if_human_present_on_idle' => true,\n        'idle_time_seconds' => 30,\n        'llm_temperature' => 0.7,\n        'enable_recording' => true,\n        'direction' => 'inbound',\n        'who_speaks_first' => 'agent'\n    ],\n]);\n$data = json_decode($response->getBody());"
          },
          "nodejs": {
            "lang": "javascript",
            "source": "const axios = require('axios');\n\nconst response = await axios.post('https://talqover.app/api/v1/agents', {\n  label: 'Customer Service Agent',\n  name: 'Customer Service Agent',\n  language: 'en-US',\n  interrupt_sensitivity: 'medium',\n  endpointing_sensitivity: 'medium',\n  ivr_navigation_mode: 'standard',\n  conversation_speed: 1.0,\n  initial_message_delay: 2,\n  ask_if_human_present_on_idle: true,\n  idle_time_seconds: 30,\n  llm_temperature: 0.7,\n  enable_recording: true,\n  direction: 'inbound',\n  who_speaks_first: 'agent'\n}, {\n  headers: {\n    'Authorization': 'Bearer YOUR_TOKEN'\n  }\n});\nconst data = response.data;"
          }
        }
      }
    },
