    "/agents/{agent}/call": {
      "post": {
        "tags": ["Calls"],
        "summary": "Make a call with an agent",
        "parameters": [
          {
            "name": "agent",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "description": "Agent ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["to"],
                "properties": {
                  "to": {
                    "type": "string",
                    "description": "Phone number to call (international format)"
                  }
                }
              },
              "example": {
                "to": "+1234567890"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Call initiated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Call"
                }
              }
            }
          },
          "422": {
            "description": "Validation error"
          }
        },
        "x-code-samples": {
          "curl": {
            "lang": "curl",
            "source": "curl -X POST \\\n  'https://talqover.app/api/v1/agents/123e4567-e89b-12d3-a456-426614174000/call' \\\n  -H 'Content-Type: application/json' \\\n  -H 'Authorization: Bearer YOUR_TOKEN' \\\n  -d '{\n    \"to\": \"+1234567890\"\n  }'"
          },
          "php": {
            "lang": "php",
            "source": "<?php\n\n$client = new \\GuzzleHttp\\Client();\n$response = $client->post('https://talqover.app/api/v1/agents/123e4567-e89b-12d3-a456-426614174000/call', [\n    'headers' => [\n        'Authorization' => 'Bearer YOUR_TOKEN',\n        'Content-Type' => 'application/json',\n    ],\n    'json' => [\n        'to' => '+1234567890'\n    ],\n]);\n$data = json_decode($response->getBody());"
          },
          "nodejs": {
            "lang": "javascript",
