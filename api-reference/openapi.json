{
  "openapi": "3.0.0",
  "info": {
    "title": "Talqover API Documentation",
    "version": "1.0.0",
    "description": "API documentation for Talqover"
  },
  "servers": [
    {
      "url": "/api/v1",
      "description": "API V1"
    }
  ],
  "paths": {
    "/user": {
      "get": {
        "tags": ["User"],
        "summary": "Get authenticated user information",
        "security": [
          {
            "sanctum": []
          }
        ],
        "responses": {
          "200": {
            "description": "User information retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "401": {
            "description": "Unauthenticated"
          }
        }
      }
    },
    "/calls/welcome": {
      "post": {
        "tags": ["Calls"],
        "summary": "Handle welcome message for calls",
        "responses": {
          "200": {
            "description": "Welcome message processed successfully"
          }
        }
      }
    },
    "/calls/welcome_ws": {
      "post": {
        "tags": ["Calls"],
        "summary": "Handle websocket welcome message",
        "responses": {
          "200": {
            "description": "Websocket welcome message processed successfully"
          }
        }
      }
    },
    "/calls/retrieve/{callSid}": {
      "post": {
        "tags": ["Calls"],
        "summary": "Retrieve call information",
        "parameters": [
          {
            "name": "callSid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Call information retrieved successfully"
          }
        }
      }
    },
    "/calls/{call}/recording": {
      "post": {
        "tags": ["Calls"],
        "summary": "Handle call recording",
        "parameters": [
          {
            "name": "call",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Recording handled successfully"
          }
        }
      }
    },
    "/agents": {
      "get": {
        "tags": ["Agents"],
        "summary": "Get list of agents",
        "responses": {
          "200": {
            "description": "List of agents retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Agent"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/agents/{agent}/call": {
      "post": {
        "tags": ["Agents"],
        "summary": "Make a call with an agent",
        "parameters": [
          {
            "name": "agent",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Call initiated successfully"
          }
        }
      }
    },
    "/tts/{filename}": {
      "get": {
        "tags": ["TTS"],
        "summary": "Get TTS audio file",
        "parameters": [
          {
            "name": "filename",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Audio file retrieved successfully",
            "content": {
              "audio/mpeg": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "404": {
            "description": "File not found"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          }
        }
      },
      "Agent": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "prompt": {
            "type": "string"
          },
          "language": {
            "type": "string"
          },
          "voice_id": {
            "type": "integer"
          },
          "initial_message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "sanctum": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
} 