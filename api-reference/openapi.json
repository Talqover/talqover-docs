{
  "openapi": "3.0.0",
  "info": {
    "title": "Talqover API Documentation",
    "version": "1.0.0",
    "description": "API documentation for Talqover - AI-powered voice conversation platform"
  },
  "servers": [
    {
      "url": "https://talqover.app/api/v1",
      "description": "Production API"
    }
