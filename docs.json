{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Talqover",
  "colors": {
    "primary": "#155DFC",
    "light": "#669BFF",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "languages": [
      {
        "language": "en",
        "default": true,
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "en/introduction"
            ]
          },
          {
            "group": "Essentials",
            "pages": [
              "en/essentials/code",
              "en/essentials/images",
              "en/essentials/markdown",
              "en/essentials/navigation",
              "en/essentials/reusable-snippets",
              "en/essentials/settings"
            ]
          },
          {
            "group": "API Reference",
            "pages": [
              "en/api-reference/introduction"
            ]
          },
          {
            "group": "Endpoints",
            "openapi": "api-reference/openapi.json"
          }
        ]
      },
      {
        "language": "pt-BR",
        "groups": [
          {
            "group": "Primeiros Passos",
            "pages": [
              "pt-br/introduction"
            ]
          },
          {
            "group": "Fundamentos",
            "pages": [
              "pt-br/essentials/code",
              "pt-br/essentials/images",
              "pt-br/essentials/markdown",
              "pt-br/essentials/navigation",
              "pt-br/essentials/reusable-snippets",
              "pt-br/essentials/settings"
            ]
          },
          {
            "group": "Referência da API",
            "pages": [
              "pt-br/api-reference/introduction"
            ]
          },
          {
            "group": "Endpoints",
            "openapi": "api-reference/openapi.json"
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Community",
          "href": "https://discord.gg/RMP4bpFrCF",
          "icon": "slack"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:contact@talqover.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.talqover.com"
    }
  },
  "footer": {
    "socials": {
      "linkedin": "https://linkedin.com/company/talqover"
    }
